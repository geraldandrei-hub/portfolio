---
import Layout from '../layouts/Layout.astro';
import { site, socials } from '../data/portfolio';

// ── Contact form delivery ────────────────────────────────────────────────
// Messages are delivered by Web3Forms (free). Get your key in 30 seconds:
//   1. Go to https://web3forms.com
//   2. Enter your email (geraldandreiv@gmail.com) — they email you an access key
//   3. Paste that key below, replacing YOUR_WEB3FORMS_ACCESS_KEY
// This key is PUBLIC-safe: it only allows sending mail to your address.
const WEB3FORMS_KEY = 'aef809c6-8c8b-429c-aa5a-07771af773d1';
---

<Layout title="Contact — Gerald Villa">
  <section class="section">
    <p class="eyebrow contact-eyebrow" data-reveal>Contact</p>
    <h2 class="contact-title" data-reveal style="--reveal-delay:70ms">Let's build something solid.</h2>
    <a href={`mailto:${site.email}`} class="contact-email" data-reveal style="--reveal-delay:140ms">{site.email}</a>

    <form class="contact-form" id="contact-form" action="https://api.web3forms.com/submit" method="POST" data-reveal style="--reveal-delay:210ms">
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="New message from your portfolio" />
      <input type="hidden" name="from_name" value="Portfolio contact form" />
      <!-- Honeypot: bots fill this, humans never see it -->
      <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" />

      <div class="field">
        <label class="field-label" for="name">Name</label>
        <input class="field-input" id="name" type="text" name="name" autocomplete="name" required />
      </div>
      <div class="field">
        <label class="field-label" for="email">Email</label>
        <input class="field-input" id="email" type="email" name="email" autocomplete="email" required />
      </div>
      <div class="field">
        <label class="field-label" for="message">Message</label>
        <textarea class="field-input field-textarea" id="message" name="message" rows="5" required></textarea>
      </div>

      <button class="btn-primary" type="submit">
        Send message
        <span class="arrow">&rarr;</span>
      </button>
      <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
    </form>

    <div class="contact-socials" data-reveal>
      {socials.map((s) => (
        <a href={s.href} class="social" target="_blank" rel="noopener noreferrer">
          <span class="social-label">{s.label}</span>
          <span class="social-handle">{s.handle}</span>
        </a>
      ))}
    </div>
  </section>

  <script>
    // Progressive enhancement: submit in the background so the visitor stays
    // on the page and gets instant feedback. Falls back to a normal POST if JS
    // is disabled. Re-binds on every view-transition navigation via
    // astro:page-load (the form element is re-created on each page swap).
    function initContactForm() {
      const form = document.getElementById('contact-form');
      if (!form || form.dataset.bound) return;
      form.dataset.bound = 'true';
      const status = document.getElementById('form-status');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type="submit"]');
        const data = new FormData(form);

        status.textContent = 'Sending…';
        status.className = 'form-status is-pending';
        btn.disabled = true;

        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: data,
          });
          const json = await res.json();
          if (json.success) {
            status.textContent = 'Thanks — your message is on its way.';
            status.className = 'form-status is-success';
            form.reset();
          } else {
            status.textContent = json.message || 'Something went wrong. Please email me directly.';
            status.className = 'form-status is-error';
          }
        } catch {
          status.textContent = 'Network error. Please email me directly.';
          status.className = 'form-status is-error';
        } finally {
          btn.disabled = false;
        }
      });
    }
    // Bind on every view-transition navigation…
    document.addEventListener('astro:page-load', initContactForm);
    // …and on the initial load even if astro:page-load already fired before this
    // module registered its listener (a swap-router race). The dataset.bound
    // guard above makes the double trigger safe — it binds the form only once.
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initContactForm);
    } else {
      initContactForm();
    }
  </script>
</Layout>
