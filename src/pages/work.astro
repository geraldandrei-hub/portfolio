---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/portfolio';
---

<Layout title="Work — Alex Mercer">
  <section class="section">
    <p class="eyebrow work-eyebrow">Projects</p>
    <h2 class="work-title">A few things I've built.</h2>

    <div class="work-list">
      {projects.map((p) => (
        <a href={p.href} target="_blank" rel="noopener noreferrer" class="project">
          <span class="project-no">{p.no}</span>
          <span class="project-shot" style={`background:${p.tint}`}>
            <span>{p.shot}</span>
          </span>
          <span class="project-body">
            <span class="project-name">{p.name}</span>
            <span class="project-desc">{p.desc}</span>
            <span class="project-tags">{p.tags}</span>
          </span>
          <span class="project-meta">
            <span class="project-year">{p.year}</span>
            <span class="project-arrow">&rarr;</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</Layout>
