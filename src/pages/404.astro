---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — Gerald Villa">
  <section class="section">
    <p class="eyebrow" style="margin-bottom:24px;">Error 404</p>
    <h2 class="contact-title">This page wandered off.</h2>
    <p class="home-intro">The link may be broken, or the page may have moved.</p>
    <div class="home-cta-row">
      <a href="/" class="btn-primary">
        Back home
        <span class="arrow">&rarr;</span>
      </a>
    </div>
  </section>
</Layout>
