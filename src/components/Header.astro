---
import { nav, site } from '../data/portfolio';

// The current path, used to highlight the active nav item.
// Astro.url.pathname is e.g. "/", "/work", "/about/".
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="header">
  <a href="/" class="brand">
    <span class="brand-dot"></span>
    <span class="brand-name">{site.name.toLowerCase()}</span>
  </a>
  <nav class="nav">
    {nav.map((n) => {
      const target = n.href.replace(/\/$/, '') || '/';
      const active = path === target;
      return (
        <a href={n.href} class={`nav-link${active ? ' is-active' : ''}`}>
          {active && <span class="nav-dot"></span>}
          {n.label}
        </a>
      );
    })}
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
      </svg>
    </button>
  </nav>
</header>
