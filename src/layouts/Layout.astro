---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/portfolio';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — ${site.role}`,
  description = `${site.role} based in ${site.location}. ${site.availability}`,
} = Astro.props;

// Canonical / share URL — only emitted once you set `site:` in astro.config.mjs.
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Restore <html> state before every paint. Runs once on first load, then
         again on astro:after-swap — the View-Transitions swap resets <html> to
         the new document's static attributes, dropping data-theme (theme would
         revert on navigation) and the reveal-ready class. after-swap fires
         before the new content paints, so there's no flash. -->
    <script is:inline>
      (function () {
        function applyHtmlState() {
          var root = document.documentElement;
          try {
            var stored = localStorage.getItem('theme');
            root.dataset.theme = stored
              || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          } catch (e) {}
          try {
            // Arm scroll-reveal only when motion is welcome. Class absent
            // (no-JS or reduced-motion) ⇒ [data-reveal] stays fully visible.
            if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
              root.classList.add('reveal-ready');
            }
          } catch (e) {}
        }
        applyHtmlState();
        document.addEventListener('astro:after-swap', applyHtmlState);
      })();
    </script>
    <ClientRouter />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- Social sharing (Open Graph + Twitter) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="app">
      <Header />
      <main class="main">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Theme toggle: delegated off `document` so it survives view-transition
         swaps (the button is re-created on every navigation). Guarded so the
         listener is only ever bound once. -->
    <script is:inline>
      (function () {
        if (window.__themeBound) return;
        window.__themeBound = true;
        document.addEventListener('click', function (e) {
          var btn = e.target.closest && e.target.closest('#theme-toggle');
          if (!btn) return;
          var next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      })();
    </script>

    <!-- Scroll reveal: fade + rise [data-reveal] elements as they enter view.
         initReveal is idempotent (it only observes :not(.is-visible) items), so
         it's safe to run from both triggers below. -->
    <script>
      function initReveal() {
        if (!document.documentElement.classList.contains('reveal-ready')) return;
        var items = document.querySelectorAll('[data-reveal]:not(.is-visible)');
        if (!('IntersectionObserver' in window)) {
          items.forEach(function (el) { el.classList.add('is-visible'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.12 });
        items.forEach(function (el) { io.observe(el); });
      }
      // Re-run after every view-transition navigation…
      document.addEventListener('astro:page-load', initReveal);
      // …and guarantee the initial load runs even if astro:page-load already
      // fired before this module registered its listener (a swap-router race).
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initReveal);
      } else {
        initReveal();
      }
    </script>
  </body>
</html>
